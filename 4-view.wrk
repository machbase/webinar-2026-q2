{"data":[{"id":"1708407645172459","contents":"# VIEW 구문 지원\n- 다양한 SELECT에 대한 사용자 정의 데이터 셋을 정의 가능\n- 권한 관리를 통한 사용자 데이터 접근 제어 가능 \n- binary 타입과 조합을 통해 추상화된 사용자 편의성 극대화 \n\n## 바이너리 데모 스키마 \n\n```sql\nCREATE TAG TABLE IF NOT EXISTS ODO_TABLE (NAME VARCHAR(32) PRIMARY KEY, TIME DATETIME BASETIME, V BINARY);\n\ncreate view odo_view as\nSELECT\n    name,\n    time,\n  EXTRACT_LE_ULONG(v,0,8)   AS hdr0,\n  EXTRACT_LE_ULONG(v,8,8)   AS hdr1,\n  EXTRACT_LE_ULONG(v,16,8)  AS hdr2,\n  EXTRACT_LE_ULONG(v,24,8)  AS imu_id,\n  EXTRACT_LE_ULONG(v,32,32) AS timeH,\n  EXTRACT_LE_ULONG(v,64,16) AS timeL,\n  EXTRACT_LE_LONG(v,80,16)  AS imu0,\n  EXTRACT_LE_LONG(v,96,16)  AS imu1,\n  EXTRACT_LE_LONG(v,112,16) AS imu2,\n  EXTRACT_LE_LONG(v,128,16) AS imu3,\n  EXTRACT_LE_LONG(v,144,16) AS imu4,\n  EXTRACT_LE_LONG(v,160,16) AS imu5,\n  EXTRACT_LE_LONG(v,176,16) AS imu6,\n  EXTRACT_LE_ULONG(v,192,16) AS odobase,\n  EXTRACT_LE_ULONG(v,208,16) AS odo0,\n  EXTRACT_LE_ULONG(v,224,16) AS odo1,\n  EXTRACT_LE_ULONG(v,240,16) AS odo2,\n  EXTRACT_LE_ULONG(v,256,16) AS odo3\n    FROM odo_table;\n```\n## 데이터 추출 SQL 형태 \n\n```sql\nselect name, time, hdr0, hdr1 from odo_view where name = 'mydata2-MFL-IMU' order by time;\nselect name, count(odo1) from odo_view where name = 'IMU' group by name order by time;\n\n```\n## 데이터 추출 질의 및 결과\n\n```sql\nselect time, hdr0, hdr1, imu_id, odo0, odo1, odo2, odo3\nfrom odo_view\nwhere name = 'mydata2-MFL-IMU'\norder by time\nlimit 3;\ntime                            hdr0                 hdr1                 imu_id               odo0                 odo1                 odo2                 odo3                 \n--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------\n2020-08-20 13:15:06 007:537:000 73                   77                   49                   1057                 1047                 765                  0                    \n2020-08-20 13:15:06 017:536:900 73                   77                   49                   1057                 1047                 765                  0                    \n2020-08-20 13:15:06 027:536:900 73                   77                   49                   1057                 1047                 765                  0                    \n[3] row(s) selected.\nMach>\n\nselect v.time, v.HDR0, v.HDR1, v.SEN_268, v.SEN_273, v.SEN_278, v.SEN_283, v.SEN_284\nfrom odo_view\nwhere v.pigtype = 'MFL'\n  and v.rectype = 'SE'\n  and v.time between '2020-08-20 13:35:26' and '2020-08-20 13:35:42'\norder by v.time\nlimit 5;\ntime                            HDR0                 HDR1                 SEN_268              SEN_273              SEN_278              SEN_283              SEN_284              \n--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------\n2020-08-20 13:35:26 135:068:700 83                   69                   15597                13241                15680                13308                14887                \n2020-08-20 13:35:28 579:940:700 83                   69                   15598                13262                15706                13405                14853                \n2020-08-20 13:35:29 267:563:600 83                   69                   15604                13313                15671                13398                14848                \n2020-08-20 13:35:29 612:552:100 83                   69                   15554                13408                15700                13482                14795                \n2020-08-20 13:35:29 780:017:700 83                   69                   15548                13407                15703                13491                14784                \n[5] row(s) selected.\nMach>\n\n```\n","height":805,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true}]}