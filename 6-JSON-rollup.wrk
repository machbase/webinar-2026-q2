{"data":[{"id":"1708407645172459","contents":"# JSON 기반의 롤업 기능 소개 \n- 혁신적인 반정형 센서 데이터(스키마)에 대한 자동화된 통계 수행\n- JSON 내부 구조를 사용자는 신경쓰지 않아도 됨.\n- 자동으로 primitive 타입(double, integer)와 완벽하게 동일하게 동작\n\n## JSON 필드 데모 스키마 \n\n```sql\ncreate tag table tag_table (\n    name varchar(20) primary key,\n    time datetime basetime,\n    value json summarized\n) with rollup extension tag_partition_count=1;\n```\n## 데이터 샘플 입력\n\n```sql\ninsert into tag_table values('AUTO_EXT', '2026-04-07 13:00:00', \n                    '{\"metrics\":{\"temp\":1,\"pressure\":10},\"location\":{\"x\":1},\"status\":\"cold\"}');\ninsert into tag_table values('AUTO_EXT', '2026-04-07 13:00:05', \n                    '{\"metrics\":{\"temp\":3,\"pressure\":30},\"location\":{\"x\":3},\"status\":\"warm\"}');\ninsert into tag_table values('AUTO_EXT', '2026-04-07 13:00:10', \n                    '{\"metrics\":{\"temp\":5,\"pressure\":50},\"location\":{\"x\":5},\"status\":\"hot\"}');\ninsert into tag_table values('AUTO_EXT', '2026-04-07 13:00:15', \n                    '{\"metrics\":{\"temp\":7,\"pressure\":70},\"location\":{\"x\":7},\"status\":\"peak\"}');\n```\n## 실시간 JSON 통계 연산 및 추출\n10초 통계 결과 \n```sql\nselect rollup('sec', 10, time) as mtime,\n       count(value),\n       avg(value),\n       sumsq(value),\n       first(time, value),\n       last(time, value)\n  from tag_table\n where name = 'AUTO_EXT'\n group by mtime\n order by mtime;\n```\n| mtime                | count(value) | avg(value)                                                                 | sumsq(value)                                                                 | first(time, value)                                                                 | last(time, value)                                                                  |\n|----------------------|--------------|-----------------------------------------------------------------------------|------------------------------------------------------------------------------|-------------------------------------------------------------------------------------|-------------------------------------------------------------------------------------|\n| 2026-04-07 13:00:00 | 2            | {\"metrics\":{\"temp\":2,\"pressure\":20},\"location\":{\"x\":2},\"status\":null}      | {\"metrics\":{\"temp\":10,\"pressure\":1000},\"location\":{\"x\":10},\"status\":null}    | {\"metrics\":{\"temp\":1,\"pressure\":10},\"location\":{\"x\":1},\"status\":\"cold\"}             | {\"metrics\":{\"temp\":3,\"pressure\":30},\"location\":{\"x\":3},\"status\":\"warm\"}             |\n| 2026-04-07 13:00:10 | 2            | {\"metrics\":{\"temp\":6,\"pressure\":60},\"location\":{\"x\":6},\"status\":null}      | {\"metrics\":{\"temp\":74,\"pressure\":7400},\"location\":{\"x\":74},\"status\":null}    | {\"metrics\":{\"temp\":5,\"pressure\":50},\"location\":{\"x\":5},\"status\":\"hot\"}              | {\"metrics\":{\"temp\":7,\"pressure\":70},\"location\":{\"x\":7},\"status\":\"peak\"}             |\n\n\n```sql\n1시간 통계 결과 \nselect rollup('hour', 1, time) as mtime,\n       count(value),\n       avg(value),\n       sumsq(value),\n       first(time, value),\n       last(time, value)\n  from tag_table\n where name = 'AUTO_EXT'\n group by mtime\n order by mtime;\n```\n| mtime                | count(value) | avg(value)                                                                 | sumsq(value)                                                                 | first(time, value)                                                                 | last(time, value)                                                                  |\n|----------------------|--------------|-----------------------------------------------------------------------------|------------------------------------------------------------------------------|-------------------------------------------------------------------------------------|-------------------------------------------------------------------------------------|\n| 2026-04-07 13:00:00 | 4            | {\"metrics\":{\"temp\":4,\"pressure\":40},\"location\":{\"x\":4},\"status\":null}      | {\"metrics\":{\"temp\":84,\"pressure\":8400},\"location\":{\"x\":84},\"status\":null}    | {\"metrics\":{\"temp\":1,\"pressure\":10},\"location\":{\"x\":1},\"status\":\"cold\"}             | {\"metrics\":{\"temp\":7,\"pressure\":70},\"location\":{\"x\":7},\"status\":\"peak\"}             |\n\n\n## ROLLUP 기반 LAG()함수를 이용한 실시간 DELTA 연산하기\n```sql\nselect name,\n       bucket_time,\n       bucket_last_flow,\n       delta\n  from (\n        select name,\n               bucket_time,\n               bucket_last_flow,\n               (bucket_last_flow - bucket_last_prev) as delta\n          from (\n                select bucket_time,\n                       name,\n                       bucket_last_flow,\n                       lag(bucket_last_flow, 1) over (partition by name order by bucket_time) as bucket_last_prev\n                  from (\n                        select bucket_time,\n                               name,\n                               json_extract_double(bucket_last, '$.sensors.flow') as bucket_last_flow\n                          from (\n                                select name,\n                                       rollup('min', 3, time) as bucket_time,\n                                       last(time, value) as bucket_last\n                                  from tag_json_delta\n                                 where name in ('EQ_DELTA_01', 'EQ_DELTA_02')\n                                   and time between '2026-04-07 09:00:00' and '2026-04-07 09:05:59'\n                                 group by name, bucket_time\n                               ) r0\n                       ) r1\n               ) r2\n       ) r3\n order by name, bucket_time;\nname                              bucket_time                     bucket_last_flow            delta                       \n-------------------------------------------------------------------------------------------------------------------------------\nEQ_DELTA_01                       2026-04-07 09:00:00 000:000:000 2895                        NULL                        \nEQ_DELTA_01                       2026-04-07 09:03:00 000:000:000 3795                        900                         \nEQ_DELTA_02                       2026-04-07 09:00:00 000:000:000 4716                        NULL                        \nEQ_DELTA_02                       2026-04-07 09:03:00 000:000:000 5436                        720                         \n[4] row(s) selected.\n```\n\n","height":805,"lineHeight":19,"minimal":false,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true}]}