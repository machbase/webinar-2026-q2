{"data":[{"id":"1708407645172459","contents":"# DISTANCE 기능 소개 \n- TIME 축 뿐만 아니라, 거리 기반의 질의도 지원 가능 \n\n## 바이너리 데모 스키마 \n\n```sql\ncreate tag table distance_table\n(\n    name         varchar(32) primary key,\n    runs         double base distance,\n    value        double,\n    quality      integer\n) metadata\n(\n    run_id    varchar(20),\n    road_id   varchar(20),\n    axis_unit varchar(8)\n);\n\n```\n## 데이터 샘플 입력 (두번째 컬럼은 거리 단위)\n\n```sql\ninsert into distance_table values('ODO_A', 0, 10.1, 100, 'RUN-001', 'A1', 'm');\ninsert into distance_table values('ODO_A', 500, 11.2, 101, 'RUN-001', 'A1', 'm');\ninsert into distance_table values('ODO_A', 1000, 12.3, 102, 'RUN-001', 'A1', 'm');\n\ninsert into distance_table values('ODO_B', 0, 20.1, 200, 'RUN-001', 'A1', 'm');\ninsert into distance_table values('ODO_B', 500, 21.2, 201, 'RUN-001', 'A1', 'm');\ninsert into distance_table values('ODO_B', 1000, 22.3, 202, 'RUN-001', 'A1', 'm');\ninsert into distance_table values('ODO_B', 1500, 23.4, 203, 'RUN-001', 'A1', 'm');\ninsert into distance_table values('ODO_B', 2000, 24.5, 204, 'RUN-001', 'A1', 'm');\ninsert into distance_table values('ODO_B', 2500, 25.6, 205, 'RUN-001', 'A1', 'm');\n\n```\n## 데이터 추출 질의 및 결과\n\n```sql\nselect name, runs, value, quality\nfrom distance_table\nwhere name = 'ODO_A'\n  and runs between 0 and 1000\norder by runs;\nname                              runs                  value                       quality\n-----------------------------------------------------------------------------------------------------------\nODO_A                             0                           10.1                        100\nODO_A                             500                         11.2                        101\nODO_A                             1000                        12.3                        102\n[3] row(s) selected.\nMach>\n\nexplain select name, runs, value, quality from distance_table where name = 'ODO_B'\n  and runs between 1000.1 and 2000\norder by runs;\nPLAN\n------------------------------------------------------------------------------------\n PROJECT\n  SORT\n   TAG READ (RAW)\n    KEYVALUE INDEX SCAN (_DISTANCE_TABLE_DATA_0)\n     [KEY RANGE]\n      * IN ()\n      * runs between 1000.1 and 2000\n    VOLATILE INDEX SCAN (_DISTANCE_TABLE_META)\n     [KEY RANGE]\n      * name = 'ODO_B'\n[10] row(s) selected.\nMach>\n\nselect name, runs, value, quality from distance_table where name = 'ODO_B'\n  and runs between 1000.1 and 2000\norder by runs;\nname                              runs                  value                       quality\n-----------------------------------------------------------------------------------------------------------\nODO_B                             1500                        23.4                        203\nODO_B                             2000                        24.5                        204\n[2] row(s) selected.\nMach>\n\n\n```\n","height":805,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true}]}